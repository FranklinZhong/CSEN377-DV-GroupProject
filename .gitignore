# ── Large data files ──────────────────────────────────────────────────────────
# Raw source files (downloaded locally, never commit)
data/raw/

# Processed CSVs and databases (generated by pipeline, too large for git)
data/processed/**/*.csv
data/processed/**/*.db
data/processed/**/*.zip
data/processed/**/*.json.zip
data/processed/OpenFDA/data/

# SQLite database (anywhere)
*.db

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.so

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Environment variables (API keys — never commit!)
.env
.env.local
.env.*.local

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
.nuxt/
.output/
.vite/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
截屏*.png
Screenshot*.png

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Internal files — not needed to run the web app ────────────────────────────
CLAUDE.md
PROGRESS.md
design/
docs/
/data/
